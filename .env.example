# LLM provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# Storage
DATABASE_URL=sqlite:///./ap_skill_generator.db

# API security (leave API_KEY empty for local dev without auth)
API_KEY=
API_HOST=127.0.0.1
API_PORT=8000
# Max POST /generate requests per client IP per 60-second window
RATE_LIMIT_GENERATE=10
# Max POST /generate/sample (free 5-question sample) attempts per client IP per 60-minute window.
# This limits abuse of the sample endpoint only; entitlement is still enforced per X-APForge-Session.
RATE_LIMIT_GENERATE_SAMPLE=3
RATE_LIMIT_ITEMS=60
CORS_ORIGINS=http://localhost:5173

# APForge Core (free sample)
APFORGE_CORE_PROVIDER=openai_compatible
APFORGE_CORE_MODEL=gpt-4o-mini
APFORGE_CORE_API_KEY=
APFORGE_CORE_BASE_URL=https://api.openai.com/v1
APFORGE_ENV=development

# Free sample + BYOK limits
FREE_SAMPLE_SIZE=5
FREE_SAMPLE_MIN_USABLE=3
FREE_MAX_REPAIR=1
FREE_ALLOW_POLICY_FALLBACK=false
FREE_ALLOW_SOFT_RETRY=false
FREE_SAMPLE_PENDING_STALE_MINUTES=15
BYOK_MAX_REPAIR=3
BYOK_CREDENTIAL_TTL_SECONDS=86400
BYOK_DEFAULT_BASE_URL=https://api.openai.com/v1
