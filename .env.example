# LLM provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# Storage
DATABASE_URL=sqlite:///./ap_skill_generator.db

# API security (leave API_KEY empty for local dev without auth)
API_KEY=
API_HOST=127.0.0.1
API_PORT=8000
RATE_LIMIT_GENERATE=10
RATE_LIMIT_ITEMS=60
CORS_ORIGINS=http://localhost:5173
